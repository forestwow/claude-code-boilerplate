{
  "_comment": "Personal overrides — copy this to settings.local.json and customize. This file is not checked into version control.",

  "_model_comment": "Set preferred model. Aliases: sonnet, opus, haiku. Or full IDs: claude-sonnet-4-6, claude-opus-4-6",
  "model": "sonnet",

  "_env_comment": "Add personal environment variables here. These merge with settings.json env.",
  "env": {
    "ANTHROPIC_API_KEY": ""
  },

  "_permissions_comment": "Add extra permissions beyond the shared defaults.",
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  }
}
